# Base de datos local/desarrollo
# Esta URL coincide con el PostgreSQL local levantado por docker-compose.yml.
DATABASE_URL="postgresql://pragma_app:pragma_dev_password@127.0.0.1:5433/pragma_works_cotizador?schema=public"

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Auth / sesiones — cambiar cuando se implemente login real
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST="true"

# Seguridad
RATE_LIMIT_ENABLED="true"
LOGIN_MAX_ATTEMPTS="5"
LOGIN_LOCK_MINUTES="15"

# Exportaciones
PDF_EXPORT_ENABLED="true"
CSV_EXPORT_ENABLED="true"

# Sólo desarrollo local. No hace falta en Vercel runtime.
SHADOW_DATABASE_URL="postgresql://pragma_app:pragma_dev_password@127.0.0.1:5433/pragma_works_cotizador_shadow?schema=public"

# Producción:
# - Configurar DATABASE_URL en Vercel con la URL de Railway PostgreSQL.
# - No subir URLs reales ni secretos a GitHub.
# - Ejecutar migraciones con:
#   DATABASE_URL="postgresql://..." npm run db:deploy
# - Ejecutar seed inicial con:
#   DATABASE_URL="postgresql://..." npm run db:seed
