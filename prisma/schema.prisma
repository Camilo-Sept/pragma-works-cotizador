// Prisma schema inicial para el backend del cotizador.
// Este archivo define la estructura segura para cotizaciones, usuarios, roles,
// catálogo, auditoría y autorizaciones comerciales.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// Roles definidos en Sprint 1.6. Los valores se guardan en minúsculas para alinearse
// con los tipos actuales de TypeScript y evitar conversiones raras en la aplicación.
enum UserRole {
  ADMIN      @map("admin")
  SUPERVISOR @map("supervisor")
  VENTAS     @map("ventas")
  OPERACION  @map("operacion")
  LECTURA    @map("lectura")
}

enum QuoteStatus {
  DRAFT    @map("draft")
  SENT     @map("sent")
  ACCEPTED @map("accepted")
  REJECTED @map("rejected")
}

enum QuoteMode {
  ONE_TIME @map("one_time")
  RENTAL   @map("rental")
  HYBRID   @map("hybrid")
}

enum SourceCodeOption {
  NONE                   @map("none")
  DELIVERY_AFTER_PAYMENT @map("delivery_after_payment")
  FULL_BUYOUT            @map("full_buyout")
}

enum BillingType {
  ONE_TIME @map("one_time")
  MONTHLY  @map("monthly")
  ANNUAL   @map("annual")
  HOURLY   @map("hourly")
}

enum ServiceCategory {
  WEB            @map("web")
  SYSTEM         @map("system")
  MOBILE         @map("mobile")
  DESKTOP        @map("desktop")
  AUTOMATION     @map("automation")
  AI             @map("ai")
  SUPPORT        @map("support")
  INFRASTRUCTURE @map("infrastructure")
  OTHER          @map("other")
}

enum ServiceSource {
  CATALOG @map("catalog")
  MANUAL  @map("manual")
}

enum AuditAction {
  CREATE          @map("create")
  UPDATE          @map("update")
  DELETE          @map("delete")
  ARCHIVE         @map("archive")
  STATUS_CHANGE   @map("status_change")
  CREATE_REVISION @map("create_revision")
  LOGIN           @map("login")
  LOGOUT          @map("logout")
  LOGIN_FAILED    @map("login_failed")

  USER_CREATE       @map("user_create")
  USER_UPDATE       @map("user_update")
  USER_DISABLE      @map("user_disable")
  USER_ENABLE       @map("user_enable")
  PASSWORD_RESET    @map("password_reset")
  PERMISSION_UPDATE @map("permission_update")

  DISCOUNT_APPLIED             @map("discount_applied")
  DISCOUNT_APPROVAL_REQUESTED @map("discount_approval_requested")
  DISCOUNT_APPROVED           @map("discount_approved")
  DISCOUNT_REJECTED           @map("discount_rejected")

  PRICE_CHANGE_REQUESTED @map("price_change_requested")
  PRICE_CHANGE_APPROVED  @map("price_change_approved")
  PRICE_CHANGE_REJECTED  @map("price_change_rejected")

  MANUAL_ITEM_REQUESTED @map("manual_item_requested")
  MANUAL_ITEM_APPROVED  @map("manual_item_approved")
  MANUAL_ITEM_REJECTED  @map("manual_item_rejected")

  CATALOG_PRICE_CHANGE_REQUESTED @map("catalog_price_change_requested")
  CATALOG_PRICE_CHANGE_APPROVED  @map("catalog_price_change_approved")
  CATALOG_PRICE_CHANGE_REJECTED  @map("catalog_price_change_rejected")

  PRICING_RULE_CHANGE_REQUESTED @map("pricing_rule_change_requested")
  PRICING_RULE_CHANGE_APPROVED  @map("pricing_rule_change_approved")
  PRICING_RULE_CHANGE_REJECTED  @map("pricing_rule_change_rejected")

  APPROVAL_REQUESTED @map("approval_requested")
  APPROVAL_APPROVED  @map("approval_approved")
  APPROVAL_REJECTED  @map("approval_rejected")
  APPROVAL_CANCELLED @map("approval_cancelled")
}

enum ApprovalType {
  DISCOUNT_OVER_10        @map("discount_over_10")
  QUOTE_ITEM_PRICE_CHANGE @map("quote_item_price_change")
  MANUAL_PRICED_ITEM      @map("manual_priced_item")
  CATALOG_PRICE_CHANGE    @map("catalog_price_change")
  PRICING_RULE_CHANGE     @map("pricing_rule_change")
}

enum ApprovalStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String?   @map("password_hash")
  role         UserRole  @default(VENTAS)
  active       Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")

  canApproveDiscountsOver10     Boolean @default(false) @map("can_approve_discounts_over_10")
  canApprovePriceChanges        Boolean @default(false) @map("can_approve_price_changes")
  canApproveManualPricedItems   Boolean @default(false) @map("can_approve_manual_priced_items")
  canApproveCatalogPriceChanges Boolean @default(false) @map("can_approve_catalog_price_changes")
  canViewAuditLogs              Boolean @default(false) @map("can_view_audit_logs")
  canExportAuditLogs            Boolean @default(false) @map("can_export_audit_logs")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quotesCreated           Quote[]           @relation("QuoteCreatedBy")
  servicesCreated         Service[]         @relation("ServiceCreatedBy")
  auditLogs               AuditLog[]        @relation("AuditActor")
  approvalRequestsCreated ApprovalRequest[] @relation("ApprovalRequestedBy")
  approvalRequestsResolved ApprovalRequest[] @relation("ApprovalResolvedBy")

  @@index([role])
  @@index([active])
  @@map("users")
}

model Client {
  id         String   @id @default(cuid())
  clientName String   @map("client_name")
  company    String?
  phone      String?
  email      String?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  quotes Quote[]

  @@index([company])
  @@index([email])
  @@map("clients")
}

model Service {
  id                  String          @id @default(cuid())
  name                String
  category            ServiceCategory
  descriptionClient   String          @map("description_client")
  descriptionInternal String?         @map("description_internal")
  billingType         BillingType     @map("billing_type")
  basePrice           Decimal         @default(0) @map("base_price") @db.Decimal(12, 2)
  estimatedHours      Decimal         @default(0) @map("estimated_hours") @db.Decimal(10, 2)
  active              Boolean         @default(true)
  source              ServiceSource   @default(CATALOG)
  requiresApproval    Boolean         @default(false) @map("requires_approval")
  createdByUserId     String?         @map("created_by_user_id")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  createdBy  User?       @relation("ServiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  quoteItems QuoteItem[]

  @@index([category])
  @@index([active])
  @@index([source])
  @@map("services")
}

model PricingRuleSet {
  id                    String   @id @default(cuid())
  name                  String
  isDefault             Boolean  @default(false) @map("is_default")
  riskPercent           Decimal  @default(0) @map("risk_percent") @db.Decimal(7, 2)
  urgencyPercent        Decimal  @default(0) @map("urgency_percent") @db.Decimal(7, 2)
  commissionPercent     Decimal  @default(0) @map("commission_percent") @db.Decimal(7, 2)
  discountPercent       Decimal  @default(0) @map("discount_percent") @db.Decimal(7, 2)
  sourceDeliveryPercent Decimal  @default(0) @map("source_delivery_percent") @db.Decimal(7, 2)
  sourceBuyoutPercent   Decimal  @default(0) @map("source_buyout_percent") @db.Decimal(7, 2)
  rentalInitialPercent  Decimal  @default(0) @map("rental_initial_percent") @db.Decimal(7, 2)
  rentalMonthlyPercent  Decimal  @default(0) @map("rental_monthly_percent") @db.Decimal(7, 2)
  hybridInitialPercent  Decimal  @default(0) @map("hybrid_initial_percent") @db.Decimal(7, 2)
  hybridMonthlyPercent  Decimal  @default(0) @map("hybrid_monthly_percent") @db.Decimal(7, 2)
  minimumOneTimePrice   Decimal  @default(0) @map("minimum_one_time_price") @db.Decimal(12, 2)
  minimumMonthlyPrice   Decimal  @default(0) @map("minimum_monthly_price") @db.Decimal(12, 2)
  websiteAnnualRenewal  Decimal  @default(0) @map("website_annual_renewal") @db.Decimal(12, 2)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  quotes Quote[]

  @@index([isDefault])
  @@map("pricing_rule_sets")
}

model Quote {
  id                  String           @id @default(cuid())
  folio               String           @unique
  status              QuoteStatus      @default(DRAFT)
  mode                QuoteMode
  sourceCodeOption    SourceCodeOption @default(NONE) @map("source_code_option")
  clientId            String           @map("client_id")
  createdByUserId     String?          @map("created_by_user_id")
  pricingRuleSetId    String?          @map("pricing_rule_set_id")

  // Reglas comerciales congeladas: una cotización enviada/aceptada debe conservar los
  // porcentajes usados aunque el catálogo o las reglas cambien después.
  rulesSnapshot Json @map("rules_snapshot")

  validUntil         DateTime  @map("valid_until")
  targetDeliveryDate DateTime? @map("target_delivery_date")
  clientNotes        String?   @map("client_notes")
  internalNotes      String?   @map("internal_notes")

  oneTimeSubtotal         Decimal @default(0) @map("one_time_subtotal") @db.Decimal(12, 2)
  monthlySubtotal         Decimal @default(0) @map("monthly_subtotal") @db.Decimal(12, 2)
  annualSubtotal          Decimal @default(0) @map("annual_subtotal") @db.Decimal(12, 2)
  hoursSubtotal           Decimal @default(0) @map("hours_subtotal") @db.Decimal(10, 2)
  riskCharge              Decimal @default(0) @map("risk_charge") @db.Decimal(12, 2)
  urgencyCharge           Decimal @default(0) @map("urgency_charge") @db.Decimal(12, 2)
  commissionCharge        Decimal @default(0) @map("commission_charge") @db.Decimal(12, 2)
  discountAmount          Decimal @default(0) @map("discount_amount") @db.Decimal(12, 2)
  sourceCodeCharge        Decimal @default(0) @map("source_code_charge") @db.Decimal(12, 2)
  suggestedInitialPayment Decimal @default(0) @map("suggested_initial_payment") @db.Decimal(12, 2)
  suggestedMonthlyPayment Decimal @default(0) @map("suggested_monthly_payment") @db.Decimal(12, 2)
  suggestedAnnualRenewal  Decimal @default(0) @map("suggested_annual_renewal") @db.Decimal(12, 2)
  estimatedHours          Decimal @default(0) @map("estimated_hours") @db.Decimal(10, 2)
  effectiveHourlyRate     Decimal @default(0) @map("effective_hourly_rate") @db.Decimal(12, 2)

  // Las revisiones evitan editar una cotización bloqueada. Ejemplo: PW-000015-R2.
  revisionOfId  String?   @map("revision_of_id")
  revisionNumber Int?     @map("revision_number")
  lockedAt      DateTime? @map("locked_at")
  archivedAt    DateTime? @map("archived_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  client           Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy        User?             @relation("QuoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  pricingRuleSet   PricingRuleSet?   @relation(fields: [pricingRuleSetId], references: [id], onDelete: SetNull)
  revisionOf       Quote?            @relation("QuoteRevisions", fields: [revisionOfId], references: [id], onDelete: Restrict)
  revisions        Quote[]           @relation("QuoteRevisions")
  items            QuoteItem[]
  auditLogs        AuditLog[]
  approvalRequests ApprovalRequest[]

  @@index([status])
  @@index([mode])
  @@index([validUntil])
  @@index([targetDeliveryDate])
  @@index([createdByUserId])
  @@index([clientId])
  @@index([revisionOfId])
  @@map("quotes")
}

model QuoteItem {
  id               String          @id @default(cuid())
  quoteId          String          @map("quote_id")
  serviceId        String?         @map("service_id")
  name             String
  category         ServiceCategory
  billingType      BillingType     @map("billing_type")
  unitPrice        Decimal         @map("unit_price") @db.Decimal(12, 2)
  quantity         Decimal         @default(1) @db.Decimal(10, 2)
  estimatedHours   Decimal         @default(0) @map("estimated_hours") @db.Decimal(10, 2)
  source           ServiceSource
  requiresApproval Boolean         @default(false) @map("requires_approval")
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  quote            Quote             @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  service          Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  approvalRequests ApprovalRequest[]

  @@index([quoteId])
  @@index([serviceId])
  @@map("quote_items")
}

model ApprovalRequest {
  id                String         @id @default(cuid())
  quoteId           String?        @map("quote_id")
  quoteItemId       String?        @map("quote_item_id")
  requestedByUserId String         @map("requested_by_user_id")
  resolvedByUserId  String?        @map("resolved_by_user_id")
  type              ApprovalType
  status            ApprovalStatus @default(PENDING)
  reason            String?
  resolutionNotes   String?        @map("resolution_notes")
  before            Json?
  after             Json?
  metadata          Json?
  requestedAt       DateTime       @default(now()) @map("requested_at")
  resolvedAt        DateTime?      @map("resolved_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  quote       Quote?     @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  quoteItem   QuoteItem? @relation(fields: [quoteItemId], references: [id], onDelete: SetNull)
  requestedBy User      @relation("ApprovalRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  resolvedBy  User?     @relation("ApprovalResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([quoteItemId])
  @@index([requestedByUserId])
  @@index([resolvedByUserId])
  @@index([type])
  @@index([status])
  @@index([requestedAt])
  @@map("approval_requests")
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?     @map("actor_user_id")
  quoteId     String?     @map("quote_id")
  action      AuditAction
  entityType  String      @map("entity_type")
  entityId    String?     @map("entity_id")
  before      Json?
  after       Json?
  metadata    Json?
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at")

  actor User?  @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  quote Quote? @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([quoteId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
